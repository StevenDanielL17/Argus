# Server
PACIFICA_API_KEY=your_api_key_here
PACIFICA_PRIVATE_KEY=your_private_key_here
BUILDER_CODE=ARGUS_BUILDER_001
PACIFICA_WS_URL=wss://ws.pacifica.fi/ws
PACIFICA_REST_URL=https://api.pacifica.fi/api/v1
PORT=8080
CORS_ORIGIN=true

# Frontend
NEXT_PUBLIC_BACKEND_WS=ws://localhost:8080/ws/client
NEXT_PUBLIC_BACKEND_REST=http://localhost:8080

# Signal Thresholds (Optional)
WHALE_THRESHOLD=50000
FUNDING_ANOMALY_THRESHOLD=0.0005
IMBALANCE_RATIO_THRESHOLD=3
WHALE_COOLDOWN_MS=15000

# Execution Layer (Optional)
EXECUTION_MODE=testnet
DEFAULT_SLIPPAGE_BPS=50
DEFAULT_TP_PCT=5
DEFAULT_SL_PCT=3
MAX_RETRIES=3
RETRY_BASE_DELAY_MS=500
REQUEST_TIMEOUT_MS=10000
REQUEST_WINDOW_MS=5000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10
